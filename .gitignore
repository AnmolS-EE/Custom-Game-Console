# For Arduino IDE Code
# Ignore built files and temporary IDE files
build/
*.elf
*.hex
*.bin
*.eep
*.o
*.a
*.core

# For KiCad files
# Ignore KiCad backups and auto-saves
*.bak
*.bck
*-bak.kicad_pcb
*-bak.kicad_sch
*-bak.sch
*.kicad_pcb-bak
*.kicad_sch-bak
_autosave-*
*.tmp
fp-info-cache
*.net

# OS Junk
# Ignore annoying hidden files generated by Windows/Mac
.DS_Store
Thumbs.db
